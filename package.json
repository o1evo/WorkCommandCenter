{
  "name": "taskforge",
  "version": "0.1.3-beta.2",
  "private": true,
  "type": "module",
  "description": "TaskForge — local, private work hub: interactive work-log page, file-bridge code review, and QA plan per task, with a Claude reviewer chat.",
  "repository": {
    "type": "git",
    "url": "https://github.com/o1evo/TaskForge.git"
  },
  "scripts": {
    "setup": "npm install && node bin/setup.mjs",
    "review": "vite",
    "build": "vite build",
    "serve": "node server/serve.mjs",
    "import": "node bin/import.mjs",
    "import-gsd": "node bin/import-gsd.mjs",
    "capture-gsd": "node bin/capture-gsd.mjs",
    "test:gsd": "node test/gsd-smoke.mjs",
    "install-skill": "node bin/install-skill.mjs",
    "uninstall-skill": "node bin/uninstall.mjs"
  },
  "license": "MIT",
  "dependencies": {
    "@babel/standalone": "^7.29.7",
    "devicon": "^2.17.0",
    "marked": "^18.0.5",
    "prismjs": "^1.30.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^5.4.11"
  }
}

# Review data contains the source under review — never commit it.
# Exception: work/sample/ is a curated demo shipped with the repo (first-run content).
work/*
!work/sample/

# Per-machine Claude Code settings (personal paths / allowlist). The committed
# skills under .claude/skills/ ARE tracked; only the local settings are ignored.
.claude/settings.local.json

node_modules/
dist/
*.log
.DS_Store

# Built VS Code extension package — produced by the release workflow, never committed.
*.vsix
# LICENSE copy the release workflow drops into the extension so it ships in the .vsix.
/vscode-extension/LICENSE

# TaskForge controller runtime state (pidfile + server log) — see bin/taskforge-mcp.mjs
.taskforge/

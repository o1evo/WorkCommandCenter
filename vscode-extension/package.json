{
  "name": "work-command-center-vscode",
  "displayName": "TaskForge",
  "description": "Render the TaskForge inside VS Code, with a one-click Start button when the server isn't running.",
  "version": "0.1.0",
  "publisher": "taskforge",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/o1evo/TaskForge.git",
    "directory": "vscode-extension"
  },
  "engines": {
    "vscode": "^1.84.0"
  },
  "main": "./extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "categories": [
    "Other"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "taskforge",
          "title": "TaskForge",
          "icon": "media/taskforge.svg"
        }
      ]
    },
    "views": {
      "taskforge": [
        {
          "id": "taskforge.sidebar",
          "name": "TaskForge",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "taskforge.open",
        "title": "TaskForge: Open",
        "category": "TaskForge"
      },
      {
        "command": "taskforge.start",
        "title": "TaskForge: Start server",
        "category": "TaskForge"
      },
      {
        "command": "taskforge.stop",
        "title": "TaskForge: Stop server",
        "category": "TaskForge"
      },
      {
        "command": "taskforge.restart",
        "title": "TaskForge: Restart server",
        "category": "TaskForge"
      },
      {
        "command": "taskforge.openExternal",
        "title": "TaskForge: Open in browser",
        "category": "TaskForge"
      },
      {
        "command": "taskforge.refresh",
        "title": "TaskForge: Refresh",
        "category": "TaskForge"
      }
    ],
    "keybindings": [
      {
        "command": "taskforge.refresh",
        "key": "f5",
        "when": "activeWebviewPanelId == 'taskforge'"
      }
    ],
    "configuration": {
      "title": "TaskForge",
      "properties": {
        "taskforge.rootPath": {
          "type": "string",
          "default": "",
          "description": "Absolute path to the TaskForge repo (the folder containing vite.config.mjs). Leave blank to auto-detect from open workspace folders, then fall back to the extension's own location."
        },
        "taskforge.port": {
          "type": "number",
          "default": 7777,
          "description": "Port TaskForge listens on (mirrors TASKFORGE_PORT)."
        },
        "taskforge.host": {
          "type": "string",
          "default": "127.0.0.1",
          "description": "Host used to build the TaskForge URL rendered in the webview (e.g. 127.0.0.1 or taskforge)."
        }
      }
    }
  }
}
